{
  "name": "@bemedev/hook-wrapper",
  "version": "0.2.0",
  "description": "Wrapper of hooks to render them in a component without recreating them.",
  "type": "module",
  "main": "lib/index.js",
  "types": "lib/index.d.ts",
  "module": "lib/index.js",
  "files": [
    "lib"
  ],
  "homepage": "https://hook-wrapper--bemedev.vercel.app",
  "author": {
    "email": "bri_lvi@icloud.com",
    "name": "chlbri",
    "url": "https://bemedev.vercel.app"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/chlbri/react-hook-wrapper"
  },
  "maintainers": [
    {
      "email": "bri_lvi@icloud.com",
      "name": "chlbri",
      "url": "https://bemedev.vercel.app"
    }
  ],
  "contributors": [
    {
      "email": "bri_lvi@icloud.com",
      "name": "chlbri",
      "url": "https://bemedev.vercel.app"
    }
  ],
  "keywords": [
    "react",
    "hook",
    "wrapper"
  ],
  "scripts": {
    "build": "pnpm run rm:lib && pnpm run rolldown",
    "rm:lib": "pnpx rimraf ./lib",
    "test": "vitest run",
    "fmt": "oxfmt",
    "lint": "oxlint --fix && pnpm run fmt",
    "pretest": "pnpm run build && pnpm run size",
    "posttest": "exit 0",
    "test:only": "pnpm run test --no-coverage",
    "_ci": "pnpm run lint && pnpm run test",
    "size": "size-limit",
    "rolldown": "rolldown -c"
  },
  "devDependencies": {
    "@bemedev/dev-utils": "^0.8.3",
    "@bemedev/shared-vitest": "workspace:^",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "jsdom": "^29.1.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "rolldown": "^1.1.4",
    "typescript": "^6.0.3",
    "vitest": "4.1.10"
  },
  "engines": {
    "node": ">=24"
  },
  "size-limit": [
    {
      "path": "lib/**/*.js",
      "limit": "10kb"
    },
    {
      "path": "lib/**/*.d.ts",
      "limit": "10kb"
    },
    {
      "path": "lib/**/*.cjs",
      "limit": "10 kb"
    }
  ]
}
